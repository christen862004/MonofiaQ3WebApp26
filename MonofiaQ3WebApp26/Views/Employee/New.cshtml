@model Employee
@{
    ViewData["Title"] = "New";
    SelectList options = new SelectList(ViewBag.DeptList,"Id","Name");//i ,name property on Department
 }

<h1>New</h1>

<form method="post" asp-action="SaveNew" asp-controller="Employee">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name"  class="form form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Salary"></label>
        <input asp-for="Salary" class="form form-control" />
        <span asp-validation-for="Salary" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" class="form form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="DepartmentId"></label>
        <select asp-for="DepartmentId" asp-items="options" class="form form-control">
            <option value="0">---Select department----</option>
        </select>
        <span asp-validation-for="DepartmentId" class="text-danger"></span>

    </div>
    <input type="submit" value="Submit" class="btn btn-success" />
</form>

<!--activate client side valiadtion-->
<a asp-action="Index" asp-controller="Employee">Back To List</a>

<!--jquery-->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<!--Jquery.valiadtion-->
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<!--Jquery.Valiadtion.unbstroive.js-->
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

